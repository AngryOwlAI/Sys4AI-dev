{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/host_capability_profile.schema.json",
  "title": "Sys4AI host capability profile",
  "description": "Structural contract for versioned reference-host metadata and fail-closed interface states. Conformance does not verify host behavior or satisfy G-07.",
  "type": "object",
  "required": [
    "profile",
    "permission_precedence",
    "interfaces"
  ],
  "properties": {
    "profile": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_version",
        "host_name",
        "host_variant",
        "portable_execution_contract_version",
        "portable_execution_contract_executable",
        "verification_state",
        "verification_gate",
        "verification_scope",
        "verification_decision",
        "verified_at",
        "verified_by",
        "source_evidence",
        "environment_scope",
        "permission_source",
        "degraded_behavior",
        "cancellation_behavior",
        "evidence_capture",
        "known_limitations",
        "review_trigger",
        "purpose_authority",
        "values_authority",
        "requirement_authority",
        "approval_authority",
        "permission_authority",
        "production_authority",
        "secrets_allowed"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "profile_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "host_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "host_variant": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "portable_execution_contract_version": {
          "oneOf": [
            {
              "const": "pending_TX_09"
            },
            {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
            }
          ]
        },
        "portable_execution_contract_executable": {
          "type": "boolean"
        },
        "verification_state": {
          "enum": [
            "draft_pending_G_07",
            "verified_G_07",
            "stale_G_07",
            "deprecated"
          ]
        },
        "verification_gate": {
          "const": "G-07"
        },
        "verification_scope": {
          "enum": [
            "structural_contract_only",
            "observable_host_conformance"
          ]
        },
        "verification_decision": {
          "oneOf": [
            {
              "const": "pending_G_07"
            },
            {
              "type": "string",
              "pattern": "^DDR-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
            }
          ]
        },
        "verified_at": {
          "$ref": "#/$defs/pendingOrRfc3339"
        },
        "verified_by": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_evidence": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "environment_scope": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "permission_source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "degraded_behavior": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cancellation_behavior": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence_capture": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "known_limitations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "review_trigger": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "purpose_authority": {
          "const": false
        },
        "values_authority": {
          "const": false
        },
        "requirement_authority": {
          "const": false
        },
        "approval_authority": {
          "const": false
        },
        "permission_authority": {
          "const": false
        },
        "production_authority": {
          "const": false
        },
        "secrets_allowed": {
          "const": false
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "verification_state": {
                "const": "draft_pending_G_07"
              }
            },
            "required": [
              "verification_state"
            ]
          },
          "then": {
            "properties": {
              "verification_scope": {
                "const": "structural_contract_only"
              },
              "verification_decision": {
                "const": "pending_G_07"
              },
              "verified_at": {
                "const": "pending_G_07"
              },
              "verified_by": {
                "const": "pending_G_07"
              },
              "portable_execution_contract_version": {
                "const": "pending_TX_09"
              },
              "portable_execution_contract_executable": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "verification_state": {
                "const": "verified_G_07"
              }
            },
            "required": [
              "verification_state"
            ]
          },
          "then": {
            "properties": {
              "verification_scope": {
                "const": "observable_host_conformance"
              },
              "verification_decision": {
                "type": "string",
                "pattern": "^DDR-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
              },
              "verified_at": {
                "$ref": "#/$defs/rfc3339"
              },
              "verified_by": {
                "allOf": [
                  {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  {
                    "not": {
                      "const": "pending_G_07"
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "permission_precedence": {
      "type": "object",
      "required": [
        "order",
        "values_or_goals_may_override"
      ],
      "properties": {
        "order": {
          "type": "array",
          "prefixItems": [
            {
              "const": "platform_and_system_constraints"
            },
            {
              "const": "host_permissions"
            },
            {
              "const": "project_authorization"
            },
            {
              "const": "bounded_transaction_permission_envelope"
            },
            {
              "const": "task_objective"
            }
          ],
          "minItems": 5,
          "maxItems": 5
        },
        "values_or_goals_may_override": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "interfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/interface"
      },
      "minItems": 8,
      "maxItems": 8
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "properties": {
              "verification_state": {
                "const": "draft_pending_G_07"
              }
            },
            "required": [
              "verification_state"
            ]
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "interfaces": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/interface"
                },
                {
                  "properties": {
                    "capability_status": {
                      "const": "unknown"
                    },
                    "execution_allowed": {
                      "const": false
                    },
                    "evidence_status": {
                      "const": "pending_G_07"
                    },
                    "evidence_checked_at": {
                      "const": "pending_G_07"
                    },
                    "evidence_fresh_until": {
                      "const": "pending_G_07"
                    },
                    "positive_probe": {
                      "const": "pending_G_07"
                    },
                    "denial_or_absence_probe": {
                      "const": "pending_G_07"
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "properties": {
              "verification_state": {
                "const": "verified_G_07"
              }
            },
            "required": [
              "verification_state"
            ]
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "interfaces": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/interface"
                },
                {
                  "properties": {
                    "evidence_status": {
                      "const": "current"
                    },
                    "evidence_checked_at": {
                      "$ref": "#/$defs/rfc3339"
                    },
                    "evidence_fresh_until": {
                      "$ref": "#/$defs/rfc3339"
                    },
                    "positive_probe": {
                      "not": {
                        "const": "pending_G_07"
                      }
                    },
                    "denial_or_absence_probe": {
                      "not": {
                        "const": "pending_G_07"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "rfc3339": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "pendingOrRfc3339": {
      "oneOf": [
        {
          "const": "pending_G_07"
        },
        {
          "$ref": "#/$defs/rfc3339"
        }
      ]
    },
    "interface": {
      "type": "object",
      "required": [
        "interface_id",
        "capability_status",
        "execution_allowed",
        "fallback_mode",
        "host_mechanism",
        "permission_source",
        "source_evidence",
        "evidence_status",
        "evidence_checked_at",
        "evidence_fresh_until",
        "positive_probe",
        "denial_or_absence_probe",
        "degraded_behavior",
        "cancellation_behavior",
        "evidence_capture",
        "known_limitations",
        "review_trigger"
      ],
      "properties": {
        "interface_id": {
          "enum": [
            "user_interaction",
            "workspace_filesystem",
            "terminal_and_tests",
            "tools_connectors_and_network",
            "sub_agents",
            "task_and_thread_state",
            "memory_and_retrieval",
            "target_runtime"
          ]
        },
        "capability_status": {
          "enum": [
            "verified_available",
            "verified_unavailable",
            "permission_dependent",
            "environment_dependent",
            "unknown",
            "deprecated"
          ]
        },
        "execution_allowed": {
          "type": "boolean"
        },
        "fallback_mode": {
          "enum": [
            "blocked",
            "degraded",
            "rerouted"
          ]
        },
        "host_mechanism": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "permission_source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_evidence": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "evidence_status": {
          "enum": [
            "pending_G_07",
            "current",
            "stale",
            "rejected",
            "not_applicable"
          ]
        },
        "evidence_checked_at": {
          "$ref": "#/$defs/pendingOrRfc3339"
        },
        "evidence_fresh_until": {
          "$ref": "#/$defs/pendingOrRfc3339"
        },
        "positive_probe": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "denial_or_absence_probe": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "degraded_behavior": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cancellation_behavior": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence_capture": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "known_limitations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "review_trigger": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "capability_status": {
                "enum": [
                  "verified_unavailable",
                  "permission_dependent",
                  "environment_dependent",
                  "unknown",
                  "deprecated"
                ]
              }
            },
            "required": [
              "capability_status"
            ]
          },
          "then": {
            "properties": {
              "execution_allowed": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "evidence_status": {
                "enum": [
                  "pending_G_07",
                  "stale",
                  "rejected",
                  "not_applicable"
                ]
              }
            },
            "required": [
              "evidence_status"
            ]
          },
          "then": {
            "properties": {
              "execution_allowed": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability_status": {
                "enum": [
                  "verified_available",
                  "verified_unavailable"
                ]
              }
            },
            "required": [
              "capability_status"
            ]
          },
          "then": {
            "properties": {
              "evidence_status": {
                "const": "current"
              },
              "evidence_checked_at": {
                "$ref": "#/$defs/rfc3339"
              },
              "evidence_fresh_until": {
                "$ref": "#/$defs/rfc3339"
              },
              "positive_probe": {
                "not": {
                  "const": "pending_G_07"
                }
              },
              "denial_or_absence_probe": {
                "not": {
                  "const": "pending_G_07"
                }
              }
            }
          }
        }
      ]
    }
  }
}
